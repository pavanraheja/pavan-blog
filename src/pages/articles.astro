---
import Layout from '@/layouts/Layout.astro';
---

<Layout title="Articles — Pavan Raheja" description="Writing on product, growth, trading, and building. By Pavan Raheja.">
  <section class="max-w-5xl mx-auto px-6 py-20">
    <h1 class="text-4xl font-bold text-gray-900 mb-4">Articles</h1>
    <p class="text-gray-500 mb-14 max-w-xl">
      Frameworks, honest takes, and lessons from scaling startups, trading markets,
      and building in public. Migrating from WordPress — new posts coming soon.
    </p>

    <!-- Placeholder — will be replaced with WordPress import -->
    <div class="space-y-6">
      <div class="p-6 rounded-xl border border-dashed border-gray-200 text-center text-gray-400 text-sm py-12">
        Articles importing from pavan.blog/WordPress — check back soon.
      </div>
    </div>

    <div class="mt-16 pt-10 border-t border-gray-100">
      <p class="text-sm text-gray-500">
        Want to read something now? <a href="/#chat" class="text-gray-900 underline underline-offset-2">Ask my digital clone</a> — it knows how I think about product, growth, and trading.
      </p>
    </div>
  </section>
</Layout>
