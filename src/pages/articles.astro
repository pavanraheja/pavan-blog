---
import Layout from '@/layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('articles')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

function formatDate(d: string) {
  return new Date(d).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' });
}
---

<Layout title="Articles — Pavan Raheja" description="Writing on product, growth, trading, and building. By Pavan Raheja.">
  <section class="max-w-5xl mx-auto px-6 py-20">
    <h1 class="text-4xl font-bold text-gray-900 mb-4">Articles</h1>
    <p class="text-gray-500 mb-14 max-w-xl">
      Frameworks, honest takes, and lessons from scaling startups, trading markets,
      and building in public.
    </p>

    <div class="divide-y divide-gray-100">
      {posts.map((post) => (
        <article class="py-7 group">
          <a href={`/articles/${post.slug}`} class="flex gap-5 items-start">
            {post.data.image && (
              <div class="flex-shrink-0 w-20 h-20 rounded-lg overflow-hidden bg-gray-100">
                <img
                  src={post.data.image}
                  alt={post.data.title}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                />
              </div>
            )}
            <div class="flex-1 min-w-0">
              <div class="flex items-start justify-between gap-4">
                <h2 class="text-base font-semibold text-gray-900 group-hover:text-brand-600 transition-colors leading-snug">
                  {post.data.title}
                </h2>
                <time class="text-xs text-gray-400 flex-shrink-0 mt-0.5">
                  {formatDate(post.data.date)}
                </time>
              </div>
              <p class="mt-1.5 text-sm text-gray-500 leading-relaxed line-clamp-2">
                {post.data.excerpt}
              </p>
            </div>
          </a>
        </article>
      ))}
    </div>
  </section>
</Layout>
