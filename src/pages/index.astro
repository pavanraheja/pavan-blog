---
import Layout from '@/layouts/Layout.astro';
import ChatWidget from '@/components/ChatWidget.astro';
import { getCollection } from 'astro:content';

const recentPosts = (await getCollection('articles'))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 4);

function formatDate(d: string) {
  return new Date(d).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' });
}
---

<Layout>
  <!-- Hero -->
  <section class="max-w-5xl mx-auto px-6 pt-20 pb-16">
    <div class="flex flex-col-reverse sm:flex-row items-center gap-10 sm:gap-16">
      <!-- Text -->
      <div class="flex-1">
        <p class="text-sm text-brand-600 font-medium mb-3">Based in Dubai, UAE</p>
        <h1 class="text-4xl sm:text-5xl font-bold text-gray-900 leading-tight tracking-tight">
          I build tech products<br />and scale startups.
        </h1>
        <p class="mt-5 text-lg text-gray-500 leading-relaxed">
          Product & Growth operator with a track record of 3× and 7× growth. I love the craft of building — from zero to one, and one to scale. Also angel invest, trade crypto markets, and write about it all.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a
            href="/#chat"
            class="bg-gray-900 text-white px-5 py-2.5 rounded-lg text-sm font-medium hover:bg-gray-700 transition-colors"
          >
            Talk to my clone
          </a>
          <a
            href="/work"
            class="border border-gray-200 text-gray-700 px-5 py-2.5 rounded-lg text-sm font-medium hover:border-gray-400 transition-colors"
          >
            See my work →
          </a>
        </div>
      </div>
      <!-- Photo -->
      <div class="flex-shrink-0">
        <div class="w-44 h-44 sm:w-56 sm:h-56 rounded-2xl overflow-hidden bg-gray-100 shadow-sm">
          <img
            src="/pavan.jpg"
            alt="Pavan Raheja"
            class="w-full h-full object-cover object-top"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Highlights strip -->
  <section class="border-y border-gray-100 bg-gray-50">
    <div class="max-w-5xl mx-auto px-6 py-10 grid sm:grid-cols-4 gap-8">
      <div>
        <p class="text-3xl font-bold text-gray-900">3×</p>
        <p class="mt-1 text-sm text-gray-500">Revenue & users at Mashkor in 18 months</p>
      </div>
      <div>
        <p class="text-3xl font-bold text-gray-900">7×</p>
        <p class="mt-1 text-sm text-gray-500">Growth at PriceLabs — 7 to 150+ people</p>
      </div>
      <div>
        <p class="text-3xl font-bold text-gray-900">5</p>
        <p class="mt-1 text-sm text-gray-500">Countries lived in across the globe</p>
      </div>
      <div>
        <p class="text-3xl font-bold text-gray-900">60+</p>
        <p class="mt-1 text-sm text-gray-500">Books read. Always learning.</p>
      </div>
    </div>
  </section>

  <!-- What I do -->
  <section class="max-w-5xl mx-auto px-6 py-20">
    <h2 class="text-xl font-semibold text-gray-900 mb-2">What I do</h2>
    <p class="text-gray-400 text-sm mb-8">The intersection of building, investing, and trading.</p>
    <div class="grid sm:grid-cols-2 gap-6">
      {[
        {
          icon: '⚙️',
          title: 'Build Tech Products',
          body: 'I love the craft of product — finding real user problems and building things that actually solve them. From activation loops to AI/ML personalization, I own the full lifecycle.',
        },
        {
          icon: '📈',
          title: 'Scale Startups',
          body: 'Growth is a system, not a hack. I build the engines — experimentation culture, data-driven funnels, cross-functional alignment — that compound over time.',
        },
        {
          icon: '🚀',
          title: 'Angel Invest',
          body: 'I invest in things I believe in and use — AI, Web3, community-driven businesses. Portfolio: xAI, GrowthX, WorldMobile, Worldcoin.',
        },
        {
          icon: '✍️',
          title: 'Write & Experiment',
          body: 'I write about product, growth, and building. On the side, I run trading bots for fun — systematic crypto experiments that keep me sharp on data and systems thinking.',
        },
      ].map((item) => (
        <div class="p-6 rounded-xl border border-gray-100 hover:border-gray-300 transition-colors">
          <span class="text-2xl mb-3 block">{item.icon}</span>
          <h3 class="font-semibold text-gray-900 mb-2">{item.title}</h3>
          <p class="text-sm text-gray-500 leading-relaxed">{item.body}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Latest articles -->
  <section class="max-w-5xl mx-auto px-6 pb-16">
    <div class="flex items-center justify-between mb-8">
      <h2 class="text-xl font-semibold text-gray-900">Latest articles</h2>
      <a href="/articles" class="text-sm text-brand-600 hover:text-brand-700 transition-colors">View all →</a>
    </div>
    <div class="divide-y divide-gray-100">
      {recentPosts.map((post) => (
        <article class="py-5 group">
          <a href={`/articles/${post.slug}`} class="flex items-start justify-between gap-4">
            <h3 class="text-sm font-medium text-gray-900 group-hover:text-brand-600 transition-colors leading-snug">
              {post.data.title}
            </h3>
            <time class="text-xs text-gray-400 flex-shrink-0 mt-0.5">{formatDate(post.data.date)}</time>
          </a>
        </article>
      ))}
    </div>
  </section>

  <!-- Newsletter -->
  <section class="max-w-5xl mx-auto px-6 pb-20">
    <div class="rounded-2xl border border-gray-100 bg-gray-50 px-8 py-10 flex flex-col sm:flex-row items-center gap-10">
      <div class="flex-1">
        <p class="text-xs font-medium text-brand-600 uppercase tracking-wide mb-2">Newsletter</p>
        <h2 class="text-2xl font-bold text-gray-900 mb-2">The Emirates Allocator</h2>
        <p class="text-sm text-gray-500 leading-relaxed">Where capital moves across UAE tech, Crypto and Real Estate. Weekly insights from someone who operates in all three.</p>
      </div>
      <div class="flex-shrink-0 w-full sm:w-auto">
        <script async src="https://subscribe-forms.beehiiv.com/embed.js"></script>
        <iframe src="https://subscribe-forms.beehiiv.com/7440ef18-7a53-490a-b513-60eac2e9b5d5" class="beehiiv-embed" data-test-id="beehiiv-embed" frameborder="0" scrolling="no" style="width: 560px; height: 291px; margin: 0; border-radius: 0px 0px 0px 0px !important; background-color: transparent; box-shadow: 0 0 #0000; max-width: 100%;"></iframe>
      </div>
    </div>
  </section>

  <!-- Digital clone chat -->
  <ChatWidget />
</Layout>
